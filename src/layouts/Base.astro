---
import '../styles/global.css';
import sofiaCyr from '@fontsource-variable/sofia-sans/files/sofia-sans-cyrillic-wght-normal.woff2?url';
import sofiaLat from '@fontsource-variable/sofia-sans/files/sofia-sans-latin-wght-normal.woff2?url';
import condCyr from '@fontsource-variable/sofia-sans-condensed/files/sofia-sans-condensed-cyrillic-wght-normal.woff2?url';
import condLat from '@fontsource-variable/sofia-sans-condensed/files/sofia-sans-condensed-latin-wght-normal.woff2?url';
import { routes, otherLang, type Lang, type PageId } from '../lib/routes';
import { common, ogLocales } from '../i18n/common';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  lang: Lang;
  pageId: PageId;
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  /** JSON-LD structured data objects rendered into <head>. */
  jsonLd?: Record<string, unknown>[];
  headerVariant?: 'home' | 'sub';
  footerNote?: string;
}

const {
  lang,
  pageId,
  title,
  description,
  ogType = 'website',
  jsonLd = [],
  headerVariant = 'sub',
  footerNote,
} = Astro.props;

const t = common[lang];
const site = Astro.site!;
const canonical = new URL(routes[pageId][lang], site);
const altBg = new URL(routes[pageId].bg, site);
const altEn = new URL(routes[pageId].en, site);
const ogImage = new URL('/og.png', site);
const preloadFonts = [sofiaCyr, sofiaLat, condCyr, condLat];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="bg" href={altBg} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="x-default" href={altBg} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-96.png" type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#f4f1ea" />
    <meta name="generator" content={Astro.generator} />
    {preloadFonts.map((href) => <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />)}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={t.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocales[lang]} />
    <meta property="og:locale:alternate" content={ogLocales[otherLang(lang)]} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd.map((data) => <script type="application/ld+json" set:html={JSON.stringify(data)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main">{t.skipToContent}</a>
    <div class="shell">
      <div class="container">
        <Header lang={lang} pageId={pageId} variant={headerVariant} />
        <slot />
        <Footer lang={lang} note={footerNote} />
      </div>
      <CookieConsent lang={lang} />
    </div>
    <script>
      // Remember the visitor's language choice when they use the toggle.
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest<HTMLElement>('[data-setlang]');
        if (!link) return;
        try {
          localStorage.setItem('pk_lang', link.dataset.setlang!);
        } catch {
          /* ignore */
        }
      });
    </script>
  </body>
</html>
